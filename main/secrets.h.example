#ifndef SECRETS_H
#define SECRETS_H

/* WiFi */
#define WIFI_SSID             "YourSSID"
#define WIFI_PASS             "YourPassword"

/* OpenWeatherMap  (free key: https://openweathermap.org/api) */
#define WEATHER_API_KEY       "your_openweathermap_api_key"

/* HuggingFace Inference API  (free: https://huggingface.co/settings/tokens) */
#define HF_API_TOKEN          "hf_your_token_here"

/* AI Voice Assistant relay server (your PC's local IP) */
#define AI_SERVER_HOST        "192.168.1.100"

/* DeepSeek API (HUD productivity assistant) */
#define DEEPSEEK_API_KEY      "your_deepseek_api_key_here"

#endif /* SECRETS_H */
